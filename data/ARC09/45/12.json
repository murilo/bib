[{"pk": 4449602, "verse": 1, "text": "Rogo-vos, pois, irm\u00e3os, pela compaix\u00e3o de Deus, que apresenteis o vosso corpo em sacrif\u00edcio vivo, santo e agrad\u00e1vel a Deus, <i>que \u00e9</i> o vosso culto racional.", "comment": "<a href='/ARC09/60/2/5'>1Pe 2:5</a><br><a href='/ARC09/19/50/14'>Sl 50:14</a><br><a href='/ARC09/45/6/13'>Rm 6:13</a><br><a href='/ARC09/46/6/20'>1Co 6:20</a><br><a href='/ARC09/58/10/20'>Hb 10:20</a>"}, {"pk": 4449603, "verse": 2, "text": "E n\u00e3o vos conformeis com este mundo, mas transformai-vos pela renova\u00e7\u00e3o do vosso entendimento, para que experimenteis qual <i>seja</i> a boa, agrad\u00e1vel e perfeita vontade de Deus.", "comment": "<a href='/ARC09/60/1/14'>1Pe 1:14</a><br><a href='/ARC09/62/2/15'>1Jo 2:15</a><br><a href='/ARC09/49/4/23'>Ef 4:23</a><br><a href='/ARC09/49/5/17'>Ef 5:17</a><br><a href='/ARC09/51/3/10'>Cl 3:10</a><br><a href='/ARC09/52/4/3'>1Ts 4:3</a>"}, {"pk": 4449604, "verse": 3, "text": "Porque, pela gra\u00e7a que me \u00e9 dada, digo a cada um dentre v\u00f3s que n\u00e3o saiba mais do que conv\u00e9m saber, mas que saiba com temperan\u00e7a, conforme a medida da f\u00e9 que Deus repartiu a cada um.", "comment": "<a href='/ARC09/45/1/5'>Rm 1:5</a><br><a href='/ARC09/45/11/20'>Rm 11:20</a><br><a href='/ARC09/46/3/10'>1Co 3:10</a><br><a href='/ARC09/46/15/10'>1Co 15:10</a><br><a href='/ARC09/48/2/9'>Gl 2:9</a><br><a href='/ARC09/49/3/2'>Ef 3:2</a><br><a href='/ARC09/49/4/7'>Ef 4:7</a><br><a href='/ARC09/20/25/27'>Pv 25:27</a><br><a href='/ARC09/21/7/16'>Ec 7:16</a><br><a href='/ARC09/46/12/11'>1Co 12:11</a>"}, {"pk": 4449605, "verse": 4, "text": "Porque assim como em um corpo temos muitos membros, e nem todos os membros t\u00eam a mesma opera\u00e7\u00e3o,", "comment": "<a href='/ARC09/46/12/12'>1Co 12:12</a><br><a href='/ARC09/49/4/16'>Ef 4:16</a>"}, {"pk": 4449606, "verse": 5, "text": "assim n\u00f3s, que somos muitos, somos um s\u00f3 corpo em Cristo, mas individualmente somos membros uns dos outros.", "comment": "<a href='/ARC09/46/10/17'>1Co 10:17</a><br><a href='/ARC09/46/12/20'>1Co 12:20</a><br><a href='/ARC09/46/12/27'>1Co 12:27</a><br><a href='/ARC09/49/1/23'>Ef 1:23</a><br><a href='/ARC09/49/4/25'>Ef 4:25</a>"}, {"pk": 4449607, "verse": 6, "text": "De modo que, tendo diferentes dons, segundo a gra\u00e7a que nos \u00e9 dada: se \u00e9 profecia, seja ela segundo a medida da f\u00e9;", "comment": "<a href='/ARC09/46/12/4'>1Co 12:4</a><br><a href='/ARC09/60/4/10-11'>1Pe 4:10-11</a><br><a href='/ARC09/44/11/27'>At 11:27</a><br><a href='/ARC09/46/12/10'>1Co 12:10</a><br><a href='/ARC09/46/12/28'>1Co 12:28</a><br><a href='/ARC09/46/14/29'>1Co 14:29</a><br><a href='/ARC09/46/14/31'>1Co 14:31</a>"}, {"pk": 4449608, "verse": 7, "text": "se \u00e9 minist\u00e9rio, seja em ministrar; se \u00e9 ensinar, haja <i>dedica\u00e7\u00e3o</i> ao ensino;", "comment": "<a href='/ARC09/44/13/1'>At 13:1</a><br><a href='/ARC09/48/6/6'>Gl 6:6</a><br><a href='/ARC09/49/4/11'>Ef 4:11</a><br><a href='/ARC09/54/5/17'>1Tm 5:17</a>"}, {"pk": 4449609, "verse": 8, "text": "ou o que exorta, <i>use esse dom</i> em exortar; o que reparte, fa\u00e7a-o com liberalidade; o que preside, com cuidado; o que exercita miseric\u00f3rdia, com alegria.", "comment": "<a href='/ARC09/44/15/32'>At 15:32</a><br><a href='/ARC09/44/20/28'>At 20:28</a><br><a href='/ARC09/46/14/3'>1Co 14:3</a><br><a href='/ARC09/54/5/17'>1Tm 5:17</a><br><a href='/ARC09/60/5/2'>1Pe 5:2</a><br><a href='/ARC09/47/9/7'>2Co 9:7</a>"}, {"pk": 4449610, "verse": 9, "text": "O amor <i>seja</i> n\u00e3o fingido. Aborrecei o mal e apegai-vos ao bem.", "comment": "<a href='/ARC09/54/1/5'>1Tm 1:5</a><br><a href='/ARC09/60/1/22'>1Pe 1:22</a><br><a href='/ARC09/19/34/14'>Sl 34:14</a><br><a href='/ARC09/30/5/15'>Am 5:15</a>"}, {"pk": 4449611, "verse": 10, "text": "Amai-vos cordialmente uns aos outros com amor fraternal, preferindo-vos em honra uns aos outros.", "comment": "<a href='/ARC09/58/13/1'>Hb 13:1</a><br><a href='/ARC09/60/1/22'>1Pe 1:22</a><br><a href='/ARC09/60/5/5'>1Pe 5:5</a><br><a href='/ARC09/61/1/7'>2Pe 1:7</a><br><a href='/ARC09/50/2/3'>Fp 2:3</a>"}, {"pk": 4449612, "verse": 11, "text": "N\u00e3o sejais vagarosos no cuidado; sede fervorosos no esp\u00edrito, servindo ao Senhor;"}, {"pk": 4449613, "verse": 12, "text": "alegrai-vos na esperan\u00e7a, sede pacientes na tribula\u00e7\u00e3o, perseverai na ora\u00e7\u00e3o;", "comment": "<a href='/ARC09/42/10/20'>Lc 10:20</a><br><a href='/ARC09/42/18/1'>Lc 18:1</a><br><a href='/ARC09/42/21/19'>Lc 21:19</a><br><a href='/ARC09/45/5/2'>Rm 5:2</a><br><a href='/ARC09/50/3/1'>Fp 3:1</a><br><a href='/ARC09/52/5/16'>1Ts 5:16</a><br><a href='/ARC09/60/2/19'>1Pe 2:19</a><br><a href='/ARC09/60/4/13'>1Pe 4:13</a><br><a href='/ARC09/54/6/11'>1Tm 6:11</a><br><a href='/ARC09/58/10/36'>Hb 10:36</a><br><a href='/ARC09/59/1/4'>Tg 1:4</a><br><a href='/ARC09/44/2/42'>At 2:42</a><br><a href='/ARC09/49/6/18'>Ef 6:18</a><br><a href='/ARC09/51/4/2'>Cl 4:2</a>"}, {"pk": 4449614, "verse": 13, "text": "comunicai com os santos nas suas necessidades, segui a hospitalidade;", "comment": "<a href='/ARC09/47/9/1'>2Co 9:1</a><br><a href='/ARC09/47/9/12'>2Co 9:12</a><br><a href='/ARC09/58/6/10'>Hb 6:10</a><br><a href='/ARC09/58/13/2'>Hb 13:2</a><br><a href='/ARC09/62/3/17'>1Jo 3:17</a><br><a href='/ARC09/60/4/9'>1Pe 4:9</a>"}, {"pk": 4449615, "verse": 14, "text": "aben\u00e7oai aos que vos perseguem; aben\u00e7oai e n\u00e3o amaldi\u00e7oeis.", "comment": "<a href='/ARC09/40/5/44'>Mt 5:44</a><br><a href='/ARC09/42/6/28'>Lc 6:28</a><br><a href='/ARC09/44/7/60'>At 7:60</a><br><a href='/ARC09/46/4/12'>1Co 4:12</a>"}, {"pk": 4449616, "verse": 15, "text": "Alegrai-vos com os que se alegram e chorai com os que choram.", "comment": "<a href='/ARC09/46/12/26'>1Co 12:26</a>"}, {"pk": 4449617, "verse": 16, "text": "Sede un\u00e2nimes entre v\u00f3s; n\u00e3o ambicioneis coisas altas, mas acomodai-vos \u00e0s humildes; n\u00e3o sejais s\u00e1bios em v\u00f3s mesmos.", "comment": "<a href='/ARC09/46/1/10'>1Co 1:10</a><br><a href='/ARC09/50/2/2'>Fp 2:2</a><br><a href='/ARC09/50/3/16'>Fp 3:16</a><br><a href='/ARC09/60/3/8'>1Pe 3:8</a>"}, {"pk": 4449618, "verse": 17, "text": "A ningu\u00e9m torneis mal por mal; procurai as <i>coisas</i> honestas perante todos os homens.", "comment": "<a href='/ARC09/20/20/22'>Pv 20:22</a><br><a href='/ARC09/40/5/39'>Mt 5:39</a><br><a href='/ARC09/52/5/15'>1Ts 5:15</a><br><a href='/ARC09/60/3/9'>1Pe 3:9</a><br><a href='/ARC09/47/8/21'>2Co 8:21</a>"}, {"pk": 4449619, "verse": 18, "text": "Se <i>for</i> poss\u00edvel, quanto estiver em v\u00f3s, tende paz com todos os homens.", "comment": "<a href='/ARC09/41/9/50'>Mc 9:50</a><br><a href='/ARC09/58/12/14'>Hb 12:14</a>"}, {"pk": 4449620, "verse": 19, "text": "N\u00e3o vos vingueis a v\u00f3s mesmos, amados, mas dai lugar \u00e0 ira, porque est\u00e1 escrito: Minha <i>\u00e9</i> a vingan\u00e7a; eu recompensarei, diz o Senhor.", "comment": "<a href='/ARC09/3/19/18'>Lv 19:18</a><br><a href='/ARC09/20/24/29'>Pv 24:29</a><br><a href='/ARC09/20/25/21'>Pv 25:21</a><br><a href='/ARC09/5/32/35'>Dt 32:35</a><br><a href='/ARC09/58/10/30'>Hb 10:30</a><br><a href='/ARC09/2/23/4-5'>\u00cax 23:4-5</a><br><a href='/ARC09/40/5/44'>Mt 5:44</a>"}, {"pk": 4449621, "verse": 20, "text": "Portanto, se o teu inimigo tiver fome, d\u00e1-lhe de comer; se tiver sede, d\u00e1-lhe de beber; porque, fazendo isto, amontoar\u00e1s brasas de fogo sobre a sua cabe\u00e7a."}, {"pk": 4449622, "verse": 21, "text": "N\u00e3o te deixes vencer do mal, mas vence o mal com o bem."}]